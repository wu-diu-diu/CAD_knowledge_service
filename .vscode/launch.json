    "version": "0.2.0",
    "configurations": [

    
        {
            "name": "文件解析测试",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test_parse_pdf.py",
            "args": ["/home/chen/punchy/CAD_knowledge_service/docs/建筑照明设计标准.pdf"],
            "console": "integratedTerminal"
        },
        {
            "name": "FastAPI: UV启动服务",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--host", "127.0.0.1",
                "--port", "8008",
            ],
            "python": "${command:python.interpreterPath}",
            "console": "integratedTerminal"
        },
        {
            "name": "CAD Agent Debug",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/agent/run.py",
            "args": [],
            "console": "integratedTerminal",
            "env": {
                "CAD_AGENT_PROVIDER": "deepseek",
                "CAD_AGENT_MODEL": "deepseek-chat",
                "CAD_AGENT_MAX_STEPS": "16",
                "default_image": "test_files/agent_test.png"
            },
            "cwd": "${workspaceFolder}"
        }
    ]
}